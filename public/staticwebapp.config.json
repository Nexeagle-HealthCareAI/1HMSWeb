{
    "$schema": "https://json.schemastore.org/staticwebapp.config.json",
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/api/*",
            "/assets/*",
            "/*.{css,js,ico,png,jpg,jpeg,gif,svg,woff,woff2,ttf,eot}"
        ]
    },
    "responseOverrides": {
        "404": {
            "rewrite": "/index.html",
            "statusCode": 200
        }
    },
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": [
                "anonymous"
            ]
        }
    ],
    "mimeTypes": {
        ".json": "application/json"
    }
}