{
    "$schema": "https://json.schemastore.org/staticwebapp.config.json",
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/api/*",
            "/assets/*",
            "/*.{css,js,ico,png,jpg,jpeg,gif,svg,woff,woff2,ttf,eot}",
            "/Images/*"
        ]
    },
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": [
                "anonymous"
            ]
        }
    ],
    "mimeTypes": {
        ".css": "text/css",
        ".js": "application/javascript",
        ".json": "application/json"
    }
}